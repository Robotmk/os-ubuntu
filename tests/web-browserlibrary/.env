# ── robotmk-starter ──────────────────────────────────────────────────────────
# RCC environment  
RMKS_ENVIRONMENT=rf-libbrowser-libcrypto
# Devcontainer type  
RMKS_DEVCONTAINER=desktop

# ── Environment ───────────────────────────────────────────────────────────────
